APP_NAME="Convalidaciones USIL"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Base de datos: MySQL 8 (motor InnoDB) — decisión confirmada
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=convalidaciones_usil
DB_USERNAME=usil
DB_PASSWORD=secret

# Colas y cache (RF-11: carga masiva en background)
QUEUE_CONNECTION=redis
CACHE_STORE=redis
REDIS_HOST=redis
REDIS_PORT=6379

SESSION_DRIVER=database
SESSION_LIFETIME=120

# Asistente de IA (RF-43) — la clave NO va en el código (RNF-09)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Motor de convalidación con IA (Gemini por defecto, gratis: https://aistudio.google.com/apikey)
IA_PROVEEDOR=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Seguridad
BCRYPT_ROUNDS=12
